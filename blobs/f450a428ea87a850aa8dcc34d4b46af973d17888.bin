 Greedy::~Greedy()=default;
 
 std::vector<Pos> Greedy::solve(State& state,Logger& logger){
+  return zigzag_horizontal(state,logger);
 }
 
 std::vector<Pos> Greedy::zigzag_horizontal(State& state,Logger& logger){
+  (void)logger;
 
+  std::vector<Pos> result;
+  result.push_back(state.pos());
+
+  const int n=static_cast<int>(state.kingdom().size());
+  auto move=[&](Direction dir){
+    bool ok=state.apply(dir);
+    assert(ok);
+    result.push_back(state.pos());
+  };
+
+  for(int i=0;i<n;i++){
+    Direction horizontal=(i%2==0)?Direction::RIGHT:Direction::LEFT;
+    for(int j=1;j<n;j++){
+      move(horizontal);
+    }
+
+    if(i+1<n){
+      move(Direction::DOWN);
+    }
+  }
+
+  return result;
 }
 
 
 std::vector<Pos> Greedy::zigzag_vertical(State& state,Logger& logger){
 
 }
