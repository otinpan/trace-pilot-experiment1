vector<pair<int,int>> zigzag_horizontal(int N) {
    vector<pair<int,int>> path;
    for (int i = 0; i < N; i++) {
        if (i % 2 == 0) {
            for (int j = 0; j < N; j++) path.push_back({i, j});
        } else {
            for (int j = N - 1; j >= 0; j--) path.push_back({i, j});
        }
    }
    return path;
}

vector<pair<int,int>> zigzag_vertical(int N) {
    vector<pair<int,int>> path;
    for (int j = 0; j < N; j++) {
        if (j % 2 == 0) {
            for (int i = 0; i < N; i++) path.push_back({i, j});
        } else {
            for (int i = N - 1; i >= 0; i--) path.push_back({i, j});
        }
    }
    return path;
}